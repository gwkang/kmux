<Window x:Class="KMux.UI.Views.TerminalWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:KMux.UI.Views"
        Title="{Binding WindowTitle, FallbackValue=KMux}"
        Width="1280" Height="800"
        MinWidth="400" MinHeight="300"
        Background="{DynamicResource KmuxBrushBase}"
        WindowStyle="SingleBorderWindow"
        PreviewKeyDown="Window_PreviewKeyDown">

  <Window.Resources>
    <!-- Tab item style -->
    <Style x:Key="TabItemStyle" TargetType="Button">
      <Setter Property="Background"   Value="Transparent" />
      <Setter Property="Foreground"   Value="{DynamicResource KmuxBrushSubtext1}" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="Padding"      Value="12,6" />
      <Setter Property="FontSize"     Value="13" />
      <Setter Property="FontFamily"   Value="Segoe UI Variable Text, Segoe UI" />
      <Setter Property="Cursor"       Value="Hand" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Border x:Name="Bd"
                    Background="{TemplateBinding Background}"
                    Padding="{TemplateBinding Padding}">
              <ContentPresenter />
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource KmuxBrushSurface0}" />
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>
  </Window.Resources>

  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="38" />   <!-- Title bar / Tab bar -->
      <RowDefinition Height="*"  />   <!-- Terminal area -->
      <RowDefinition Height="22" />   <!-- Status bar -->
    </Grid.RowDefinitions>

    <!-- ── Tab bar ────────────────────────────────────────────────────────── -->
    <Grid Grid.Row="0" Background="{DynamicResource KmuxBrushMantle}">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="Auto" />  <!-- app icon -->
        <ColumnDefinition Width="*"    />  <!-- tabs -->
        <ColumnDefinition Width="Auto" />  <!-- actions -->
      </Grid.ColumnDefinitions>

      <!-- App icon/name -->
      <TextBlock Grid.Column="0"
                 Text="⬡ KMux"
                 Foreground="{DynamicResource KmuxBrushAccent}"
                 FontWeight="Bold"
                 FontSize="13"
                 VerticalAlignment="Center"
                 Margin="12,0" />

      <!-- Tabs -->
      <ScrollViewer Grid.Column="1"
                    HorizontalScrollBarVisibility="Auto"
                    VerticalScrollBarVisibility="Disabled">
        <ItemsControl x:Name="TabItemsControl"
                      ItemsSource="{Binding Tabs}">
          <ItemsControl.ItemsPanel>
            <ItemsPanelTemplate>
              <StackPanel Orientation="Horizontal" />
            </ItemsPanelTemplate>
          </ItemsControl.ItemsPanel>
          <ItemsControl.ItemTemplate>
            <DataTemplate>
              <Grid>
                <Button Style="{StaticResource TabItemStyle}"
                        Click="TabButton_Click"
                        Tag="{Binding}"
                        ToolTip="{Binding ToolTipText}">
                  <StackPanel Orientation="Horizontal">
                    <!-- Tab selected indicator dot (accent color) -->
                    <Ellipse Width="6" Height="6" Margin="0,0,2,0">
                      <Ellipse.Style>
                        <Style TargetType="Ellipse">
                          <Setter Property="Fill" Value="Transparent"/>
                          <Style.Triggers>
                            <DataTrigger Binding="{Binding IsActive}" Value="True">
                              <Setter Property="Fill" Value="{DynamicResource KmuxBrushAccent}"/>
                            </DataTrigger>
                          </Style.Triggers>
                        </Style>
                      </Ellipse.Style>
                    </Ellipse>
                    <!-- Claude busy indicator dot (green, pulsing) -->
                    <Ellipse Width="6" Height="6" Margin="0,0,4,0" Opacity="0">
                      <Ellipse.Style>
                        <Style TargetType="Ellipse">
                          <Setter Property="Fill" Value="{DynamicResource KmuxBrushGreen}"/>
                          <Style.Triggers>
                            <DataTrigger Binding="{Binding IsBusy}" Value="True">
                              <DataTrigger.EnterActions>
                                <BeginStoryboard Name="BusyPulse">
                                  <Storyboard RepeatBehavior="Forever">
                                    <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                     From="0.4" To="1.0"
                                                     Duration="0:0:0.7"
                                                     AutoReverse="True">
                                      <DoubleAnimation.EasingFunction>
                                        <SineEase />
                                      </DoubleAnimation.EasingFunction>
                                    </DoubleAnimation>
                                  </Storyboard>
                                </BeginStoryboard>
                              </DataTrigger.EnterActions>
                              <DataTrigger.ExitActions>
                                <StopStoryboard BeginStoryboardName="BusyPulse" />
                                <BeginStoryboard>
                                  <Storyboard>
                                    <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                     To="0" Duration="0:0:0.3" />
                                  </Storyboard>
                                </BeginStoryboard>
                              </DataTrigger.ExitActions>
                            </DataTrigger>
                          </Style.Triggers>
                        </Style>
                      </Ellipse.Style>
                    </Ellipse>
                    <TextBlock Text="{Binding Title}">
                      <TextBlock.Style>
                        <Style TargetType="TextBlock">
                          <Setter Property="Foreground" Value="{DynamicResource KmuxBrushSubtext1}"/>
                          <Style.Triggers>
                            <DataTrigger Binding="{Binding IsActive}" Value="True">
                              <Setter Property="Foreground" Value="{DynamicResource KmuxBrushText}"/>
                            </DataTrigger>
                          </Style.Triggers>
                        </Style>
                      </TextBlock.Style>
                    </TextBlock>
                    <Button Background="Transparent"
                            Foreground="{DynamicResource KmuxBrushOverlay0}"
                            BorderThickness="0"
                            FontSize="11"
                            Padding="2,0"
                            Content="✕"
                            Click="CloseTabButton_Click"
                            Tag="{Binding}"
                            Cursor="Hand" />
                  </StackPanel>
                </Button>
                <!-- Active indicator bar -->
                <Rectangle Height="2"
                           VerticalAlignment="Bottom"
                           HorizontalAlignment="Stretch"
                           Margin="4,0">
                  <Rectangle.Style>
                    <Style TargetType="Rectangle">
                      <Setter Property="Fill" Value="Transparent"/>
                      <Style.Triggers>
                        <DataTrigger Binding="{Binding IsActive}" Value="True">
                          <Setter Property="Fill" Value="{DynamicResource KmuxBrushAccent}"/>
                        </DataTrigger>
                      </Style.Triggers>
                    </Style>
                  </Rectangle.Style>
                </Rectangle>
              </Grid>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>
      </ScrollViewer>

      <!-- Action buttons -->
      <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
        <!-- New tab (right-click → recent folders) -->
        <Button Style="{StaticResource TabItemStyle}"
                Content="+" FontSize="18" FontWeight="Light"
                ToolTip="New tab (Ctrl+Shift+T) · Right-click for recent folders"
                Click="NewTabButton_Click"
                ContextMenuOpening="NewTab_ContextMenuOpening">
          <Button.ContextMenu><ContextMenu /></Button.ContextMenu>
        </Button>
        <!-- Split H: two panes stacked with horizontal divider -->
        <Button Style="{StaticResource TabItemStyle}"
                ToolTip="Split horizontal (Ctrl+B -)"
                Click="SplitHButton_Click">
          <Canvas Width="16" Height="14">
            <Rectangle Canvas.Left="0" Canvas.Top="0"  Width="16" Height="5"  Fill="{DynamicResource KmuxBrushSubtext1}" RadiusX="1" RadiusY="1" />
            <Rectangle Canvas.Left="0" Canvas.Top="9"  Width="16" Height="5"  Fill="{DynamicResource KmuxBrushSubtext1}" RadiusX="1" RadiusY="1" />
            <Rectangle Canvas.Left="0" Canvas.Top="6"  Width="16" Height="2"  Fill="{DynamicResource KmuxBrushAccent}" />
          </Canvas>
        </Button>
        <!-- Split V: two panes side by side with vertical divider -->
        <Button Style="{StaticResource TabItemStyle}"
                ToolTip="Split vertical (Ctrl+B \)"
                Click="SplitVButton_Click">
          <Canvas Width="14" Height="14">
            <Rectangle Canvas.Left="0"  Canvas.Top="0" Width="5"  Height="14" Fill="{DynamicResource KmuxBrushSubtext1}" RadiusX="1" RadiusY="1" />
            <Rectangle Canvas.Left="9"  Canvas.Top="0" Width="5"  Height="14" Fill="{DynamicResource KmuxBrushSubtext1}" RadiusX="1" RadiusY="1" />
            <Rectangle Canvas.Left="6"  Canvas.Top="0" Width="2"  Height="14" Fill="{DynamicResource KmuxBrushAccent}" />
          </Canvas>
        </Button>
        <!-- Macro record -->
        <Button x:Name="RecordButton"
                Style="{StaticResource TabItemStyle}"
                Content="⏺" FontSize="14"
                ToolTip="Record macro (Ctrl+B R)"
                Click="RecordButton_Click" />
        <!-- New window (right-click → recent folders) -->
        <Button Style="{StaticResource TabItemStyle}"
                Content="⊞" FontSize="14"
                ToolTip="New window (Ctrl+Shift+N) · Right-click for recent folders"
                Click="NewWindowButton_Click"
                ContextMenuOpening="NewWindow_ContextMenuOpening">
          <Button.ContextMenu><ContextMenu /></Button.ContextMenu>
        </Button>
        <!-- Recent folders manager -->
        <Button Style="{StaticResource TabItemStyle}"
                Content="📂" FontSize="14"
                ToolTip="Recent folders"
                Click="RecentFoldersButton_Click" />
        <!-- Session manager -->
        <Button Style="{StaticResource TabItemStyle}"
                Content="💾" FontSize="14"
                ToolTip="Session manager (Ctrl+B O)"
                Click="SessionButton_Click" />
        <!-- Macro manager -->
        <Button Style="{StaticResource TabItemStyle}"
                Content="📋" FontSize="14"
                ToolTip="Macro manager (Ctrl+B M)"
                Click="MacroButton_Click" />
        <!-- Settings -->
        <Button Style="{StaticResource TabItemStyle}"
                Content="⚙" FontSize="14"
                ToolTip="Settings"
                Click="SettingsButton_Click" />
      </StackPanel>
    </Grid>

    <!-- ── Pane area ──────────────────────────────────────────────────────── -->
    <local:PaneContainer x:Name="PaneContainer"
                         Grid.Row="1"
                         Tab="{Binding ActiveTab}"
                         AssetsPath="{Binding AssetsPath, RelativeSource={RelativeSource AncestorType=Window}}" />

    <!-- ── Status bar ────────────────────────────────────────────────────── -->
    <Grid Grid.Row="2" Background="{DynamicResource KmuxBrushCrust}">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="*" />
        <ColumnDefinition Width="Auto" />
      </Grid.ColumnDefinitions>

      <TextBlock Grid.Column="0"
                 x:Name="StatusText"
                 Text="Ready"
                 Foreground="{DynamicResource KmuxBrushSubtext0}"
                 FontSize="11"
                 VerticalAlignment="Center"
                 Margin="8,0" />

      <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="8,0">
        <TextBlock x:Name="RecordingIndicator"
                   Text="⏺ RECORDING"
                   Foreground="{DynamicResource KmuxBrushRed}"
                   FontSize="11"
                   FontWeight="Bold"
                   VerticalAlignment="Center"
                   Margin="0,0,12,0"
                   Visibility="Collapsed" />
        <TextBlock Text="Ctrl+B → prefix"
                   Foreground="{DynamicResource KmuxBrushSurface1}"
                   FontSize="11"
                   VerticalAlignment="Center" />
      </StackPanel>
    </Grid>
  </Grid>
</Window>
