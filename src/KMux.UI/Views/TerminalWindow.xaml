<Window x:Class="KMux.UI.Views.TerminalWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:KMux.UI.Views"
        Title="{Binding WindowTitle, FallbackValue=KMux}"
        Icon="pack://application:,,,/KMux;component/Assets/kmux.ico"
        Width="1280" Height="800"
        MinWidth="400" MinHeight="300"
        Background="{DynamicResource KmuxBrushBase}"
        WindowStyle="SingleBorderWindow"
        PreviewKeyDown="Window_PreviewKeyDown">

  <Window.Resources>
    <!-- Toolbar icon style (Segoe MDL2 Assets glyphs) — inherits Foreground from parent button -->
    <Style x:Key="MdlIcon" TargetType="TextBlock">
      <Setter Property="FontFamily"        Value="Segoe MDL2 Assets"/>
      <Setter Property="FontSize"          Value="13"/>
      <Setter Property="VerticalAlignment" Value="Center"/>
      <Setter Property="IsHitTestVisible"  Value="False"/>
    </Style>

    <!-- Base tab/toolbar button style -->
    <Style x:Key="TabItemStyle" TargetType="Button">
      <Setter Property="Background"      Value="Transparent"/>
      <Setter Property="Foreground"      Value="{DynamicResource KmuxBrushSubtext1}"/>
      <Setter Property="BorderThickness" Value="0"/>
      <Setter Property="Padding"         Value="10,6"/>
      <Setter Property="FontSize"        Value="13"/>
      <Setter Property="FontFamily"      Value="Segoe UI Variable Text, Segoe UI"/>
      <Setter Property="Cursor"          Value="Hand"/>
      <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Border x:Name="Bd"
                    Background="{TemplateBinding Background}"
                    Padding="{TemplateBinding Padding}"
                    CornerRadius="3">
              <ContentPresenter VerticalAlignment="Center" HorizontalAlignment="Center"/>
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource KmuxBrushSurface0}"/>
                <Setter Property="Foreground" Value="{DynamicResource KmuxBrushText}"/>
              </Trigger>
              <Trigger Property="IsPressed" Value="True">
                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource KmuxBrushSurface1}"/>
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <!-- Close (✕) button inside tab -->
    <Style x:Key="TabCloseStyle" TargetType="Button">
      <Setter Property="Background"      Value="Transparent"/>
      <Setter Property="Foreground"      Value="{DynamicResource KmuxBrushOverlay0}"/>
      <Setter Property="BorderThickness" Value="0"/>
      <Setter Property="Padding"         Value="3,1"/>
      <Setter Property="FontSize"        Value="11"/>
      <Setter Property="Cursor"          Value="Hand"/>
      <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
      <Setter Property="VerticalAlignment" Value="Center"/>
      <Setter Property="HorizontalAlignment" Value="Right"/>
      <Setter Property="Margin"          Value="0,0,3,0"/>
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Border x:Name="Bd"
                    Background="{TemplateBinding Background}"
                    Padding="{TemplateBinding Padding}"
                    CornerRadius="3">
              <ContentPresenter VerticalAlignment="Center" HorizontalAlignment="Center"/>
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource KmuxBrushSurface1}"/>
                <Setter Property="Foreground" Value="{DynamicResource KmuxBrushText}"/>
              </Trigger>
              <Trigger Property="IsPressed" Value="True">
                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource KmuxBrushSurface0}"/>
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <!-- Vertical separator for toolbar -->
    <Style x:Key="ToolbarSep" TargetType="Rectangle">
      <Setter Property="Width"             Value="1"/>
      <Setter Property="Height"            Value="16"/>
      <Setter Property="Fill"              Value="{DynamicResource KmuxBrushSurface1}"/>
      <Setter Property="Margin"            Value="4,0"/>
      <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>
  </Window.Resources>

  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="38" />   <!-- Tab bar -->
      <RowDefinition Height="*"  />   <!-- Terminal area -->
      <RowDefinition Height="22" />   <!-- Status bar -->
    </Grid.RowDefinitions>

    <!-- ── Tab bar ────────────────────────────────────────────────────────── -->
    <Grid Grid.Row="0" Background="{DynamicResource KmuxBrushMantle}">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="Auto" />  <!-- app icon -->
        <ColumnDefinition Width="*"    />  <!-- tabs -->
        <ColumnDefinition Width="Auto" />  <!-- actions -->
      </Grid.ColumnDefinitions>

      <!-- App icon/name -->
      <StackPanel Grid.Column="0" Orientation="Horizontal" Margin="12,0,8,0" VerticalAlignment="Center">
        <Viewbox Width="14" Height="14" Margin="0,0,6,0">
          <Canvas Width="16" Height="16">
            <Path Fill="{DynamicResource KmuxBrushAccent}" IsHitTestVisible="False"
                  Data="M8,1 L14.7,4.8 L14.7,11.2 L8,15 L1.3,11.2 L1.3,4.8 Z"/>
          </Canvas>
        </Viewbox>
        <TextBlock Text="KMux"
                   Foreground="{DynamicResource KmuxBrushAccent}"
                   FontWeight="Bold" FontSize="13" VerticalAlignment="Center"/>
      </StackPanel>

      <!-- Tabs — hidden scrollbar, mouse-wheel scrollable -->
      <ScrollViewer Grid.Column="1"
                    HorizontalScrollBarVisibility="Hidden"
                    VerticalScrollBarVisibility="Disabled">
        <ItemsControl x:Name="TabItemsControl"
                      ItemsSource="{Binding Tabs}">
          <ItemsControl.ItemsPanel>
            <ItemsPanelTemplate>
              <StackPanel Orientation="Horizontal" />
            </ItemsPanelTemplate>
          </ItemsControl.ItemsPanel>
          <ItemsControl.ItemTemplate>
            <DataTemplate>
              <!-- Grid: tab button + close button as siblings (no nesting) -->
              <Grid AllowDrop="True"
                    PreviewMouseLeftButtonDown="TabItem_PreviewMouseLeftButtonDown"
                    PreviewMouseMove="TabItem_PreviewMouseMove"
                    Drop="TabItem_Drop"
                    DragOver="TabItem_DragOver">
                <!-- Tab select button — full area, right padding reserves space for ✕ -->
                <Button Style="{StaticResource TabItemStyle}"
                        Click="TabButton_Click"
                        Tag="{Binding}"
                        ToolTip="{Binding ToolTipText}"
                        Padding="10,6,20,6">
                  <Button.Background>
                    <SolidColorBrush Color="Transparent"/>
                  </Button.Background>
                  <Button.Template>
                    <ControlTemplate TargetType="Button">
                      <Border x:Name="Bd"
                              Background="{TemplateBinding Background}"
                              Padding="{TemplateBinding Padding}">
                        <ContentPresenter VerticalAlignment="Center"/>
                      </Border>
                      <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                          <Setter TargetName="Bd" Property="Background" Value="{DynamicResource KmuxBrushSurface0}"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                          <Setter TargetName="Bd" Property="Background" Value="{DynamicResource KmuxBrushSurface1}"/>
                        </Trigger>
                        <DataTrigger Binding="{Binding IsActive}" Value="True">
                          <Setter TargetName="Bd" Property="Background" Value="{DynamicResource KmuxBrushSurface0}"/>
                        </DataTrigger>
                      </ControlTemplate.Triggers>
                    </ControlTemplate>
                  </Button.Template>
                  <StackPanel Orientation="Horizontal">
                    <!-- Dashboard icon — only shown for the dashboard tab -->
                    <TextBlock FontFamily="Segoe MDL2 Assets" FontSize="11"
                               Text="&#xF246;" Margin="0,0,5,0" VerticalAlignment="Center">
                      <TextBlock.Style>
                        <Style TargetType="TextBlock">
                          <Setter Property="Visibility" Value="Collapsed"/>
                          <Setter Property="Foreground" Value="{DynamicResource KmuxBrushAccent}"/>
                          <Style.Triggers>
                            <DataTrigger Binding="{Binding IsDashboard}" Value="True">
                              <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                          </Style.Triggers>
                        </Style>
                      </TextBlock.Style>
                    </TextBlock>
                    <!-- Active indicator dot (accent) — hidden for dashboard -->
                    <Ellipse Width="6" Height="6" Margin="0,0,2,0">
                      <Ellipse.Style>
                        <Style TargetType="Ellipse">
                          <Setter Property="Fill" Value="Transparent"/>
                          <Style.Triggers>
                            <DataTrigger Binding="{Binding IsDashboard}" Value="True">
                              <Setter Property="Visibility" Value="Collapsed"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding IsActive}" Value="True">
                              <Setter Property="Fill" Value="{DynamicResource KmuxBrushAccent}"/>
                            </DataTrigger>
                          </Style.Triggers>
                        </Style>
                      </Ellipse.Style>
                    </Ellipse>
                    <!-- Claude busy indicator: square shape (distinct from circle = different meaning), pulsing — hidden for dashboard -->
                    <Rectangle Width="6" Height="6" Margin="0,0,5,0" Opacity="0"
                               RadiusX="1" RadiusY="1">
                      <Rectangle.Style>
                        <Style TargetType="Rectangle">
                          <Setter Property="Fill" Value="{DynamicResource KmuxBrushGreen}"/>
                          <Style.Triggers>
                            <DataTrigger Binding="{Binding IsDashboard}" Value="True">
                              <Setter Property="Visibility" Value="Collapsed"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding IsBusy}" Value="True">
                              <DataTrigger.EnterActions>
                                <BeginStoryboard Name="BusyPulse">
                                  <Storyboard RepeatBehavior="Forever">
                                    <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                     From="0.4" To="1.0"
                                                     Duration="0:0:0.7"
                                                     AutoReverse="True">
                                      <DoubleAnimation.EasingFunction>
                                        <SineEase />
                                      </DoubleAnimation.EasingFunction>
                                    </DoubleAnimation>
                                  </Storyboard>
                                </BeginStoryboard>
                              </DataTrigger.EnterActions>
                              <DataTrigger.ExitActions>
                                <StopStoryboard BeginStoryboardName="BusyPulse" />
                                <BeginStoryboard>
                                  <Storyboard>
                                    <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                     To="0" Duration="0:0:0.3" />
                                  </Storyboard>
                                </BeginStoryboard>
                              </DataTrigger.ExitActions>
                            </DataTrigger>
                          </Style.Triggers>
                        </Style>
                      </Rectangle.Style>
                    </Rectangle>
                    <!-- Tab title: TextBlock (display) / TextBox (rename, double-click to activate) -->
                    <TextBlock Text="{Binding Title}"
                               PreviewMouseLeftButtonDown="TabTitle_PreviewMouseLeftButtonDown">
                      <TextBlock.Style>
                        <Style TargetType="TextBlock">
                          <Setter Property="Foreground" Value="{DynamicResource KmuxBrushSubtext1}"/>
                          <Style.Triggers>
                            <DataTrigger Binding="{Binding IsDashboard}" Value="True">
                              <Setter Property="Foreground" Value="{DynamicResource KmuxBrushAccent}"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding IsActive}" Value="True">
                              <Setter Property="Foreground" Value="{DynamicResource KmuxBrushText}"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding IsRenaming}" Value="True">
                              <Setter Property="Visibility" Value="Collapsed"/>
                            </DataTrigger>
                          </Style.Triggers>
                        </Style>
                      </TextBlock.Style>
                    </TextBlock>
                    <TextBox MinWidth="60" MaxWidth="140" FontSize="11"
                             Background="{DynamicResource KmuxBrushSurface0}"
                             Foreground="{DynamicResource KmuxBrushText}"
                             CaretBrush="{DynamicResource KmuxBrushText}"
                             BorderThickness="0" Padding="2,0"
                             VerticalContentAlignment="Center"
                             IsVisibleChanged="TabTitleEdit_IsVisibleChanged"
                             LostFocus="TabTitleEdit_LostFocus"
                             KeyDown="TabTitleEdit_KeyDown">
                      <TextBox.Style>
                        <Style TargetType="TextBox">
                          <Setter Property="Visibility" Value="Collapsed"/>
                          <Style.Triggers>
                            <DataTrigger Binding="{Binding IsRenaming}" Value="True">
                              <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                          </Style.Triggers>
                        </Style>
                      </TextBox.Style>
                    </TextBox>
                  </StackPanel>
                </Button>

                <!-- Close button — hidden for dashboard tab -->
                <Button Click="CloseTabButton_Click"
                        Tag="{Binding}">
                  <Button.Style>
                    <Style TargetType="Button" BasedOn="{StaticResource TabCloseStyle}">
                      <Setter Property="Visibility" Value="Visible"/>
                      <Style.Triggers>
                        <DataTrigger Binding="{Binding IsDashboard}" Value="True">
                          <Setter Property="Visibility" Value="Collapsed"/>
                        </DataTrigger>
                      </Style.Triggers>
                    </Style>
                  </Button.Style>
                  <Viewbox Width="9" Height="9">
                    <Canvas Width="12" Height="12">
                      <Path Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                            StrokeThickness="1.8" StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                            IsHitTestVisible="False"
                            Data="M2,2 L10,10 M10,2 L2,10"/>
                    </Canvas>
                  </Viewbox>
                </Button>

                <!-- Active indicator bar at bottom -->
                <Rectangle Height="2"
                           VerticalAlignment="Bottom"
                           HorizontalAlignment="Stretch"
                           Margin="4,0">
                  <Rectangle.Style>
                    <Style TargetType="Rectangle">
                      <Setter Property="Fill" Value="Transparent"/>
                      <Style.Triggers>
                        <DataTrigger Binding="{Binding IsActive}" Value="True">
                          <Setter Property="Fill" Value="{DynamicResource KmuxBrushAccent}"/>
                        </DataTrigger>
                      </Style.Triggers>
                    </Style>
                  </Rectangle.Style>
                </Rectangle>
              </Grid>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>
      </ScrollViewer>

      <!-- ── Toolbar action buttons ─────────────────────────────────────── -->
      <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center" Margin="4,0">

        <!-- Group 1: New tab -->
        <Button Style="{StaticResource TabItemStyle}"
                ToolTip="New tab (Ctrl+Shift+T) · Right-click for recent folders"
                Click="NewTabButton_Click"
                ContextMenuOpening="NewTab_ContextMenuOpening"
                Padding="8,6">
          <Button.ContextMenu><ContextMenu /></Button.ContextMenu>
          <TextBlock Style="{StaticResource MdlIcon}" Text="&#xE710;" FontSize="15" FontFamily="Segoe MDL2 Assets"/>
        </Button>

        <Rectangle Style="{StaticResource ToolbarSep}"/>

        <!-- Group 2: Layout -->
        <Button Style="{StaticResource TabItemStyle}"
                ToolTip="Split horizontal (Ctrl+B -)"
                Click="SplitHButton_Click">
          <Canvas Width="16" Height="14">
            <Rectangle Canvas.Left="0" Canvas.Top="0"  Width="16" Height="5"  Fill="{DynamicResource KmuxBrushSubtext1}" RadiusX="1" RadiusY="1" />
            <Rectangle Canvas.Left="0" Canvas.Top="9"  Width="16" Height="5"  Fill="{DynamicResource KmuxBrushSubtext1}" RadiusX="1" RadiusY="1" />
            <Rectangle Canvas.Left="0" Canvas.Top="6"  Width="16" Height="2"  Fill="{DynamicResource KmuxBrushAccent}" />
          </Canvas>
        </Button>
        <Button Style="{StaticResource TabItemStyle}"
                ToolTip="Split vertical (Ctrl+B \)"
                Click="SplitVButton_Click">
          <Canvas Width="14" Height="14">
            <Rectangle Canvas.Left="0"  Canvas.Top="0" Width="5"  Height="14" Fill="{DynamicResource KmuxBrushSubtext1}" RadiusX="1" RadiusY="1" />
            <Rectangle Canvas.Left="9"  Canvas.Top="0" Width="5"  Height="14" Fill="{DynamicResource KmuxBrushSubtext1}" RadiusX="1" RadiusY="1" />
            <Rectangle Canvas.Left="6"  Canvas.Top="0" Width="2"  Height="14" Fill="{DynamicResource KmuxBrushAccent}" />
          </Canvas>
        </Button>

        <Rectangle Style="{StaticResource ToolbarSep}"/>

        <!-- Group 3: Record -->
        <Button x:Name="RecordButton"
                Style="{StaticResource TabItemStyle}"
                ToolTip="Record macro (Ctrl+B R)"
                Click="RecordButton_Click">
          <TextBlock Style="{StaticResource MdlIcon}" Text="&#xEA3A;"/>
        </Button>

        <Rectangle Style="{StaticResource ToolbarSep}"/>

        <!-- Group 4: Window / tools -->
        <Button Style="{StaticResource TabItemStyle}"
                ToolTip="New window (Ctrl+Shift+N) · Right-click for recent folders"
                Click="NewWindowButton_Click"
                ContextMenuOpening="NewWindow_ContextMenuOpening">
          <Button.ContextMenu><ContextMenu /></Button.ContextMenu>
          <TextBlock Style="{StaticResource MdlIcon}" Text="&#xE8A7;"/>
        </Button>
        <Button Style="{StaticResource TabItemStyle}"
                ToolTip="Recent folders"
                Click="RecentFoldersButton_Click">
          <TextBlock Style="{StaticResource MdlIcon}" Text="&#xE8B7;"/>
        </Button>
        <Button Style="{StaticResource TabItemStyle}"
                ToolTip="Session manager (Ctrl+B O)"
                Click="SessionButton_Click">
          <TextBlock Style="{StaticResource MdlIcon}" Text="&#xE74E;"/>
        </Button>
        <Button Style="{StaticResource TabItemStyle}"
                ToolTip="Macro manager (Ctrl+B M)"
                Click="MacroButton_Click">
          <TextBlock Style="{StaticResource MdlIcon}" Text="&#xE8A5;"/>
        </Button>

        <Rectangle Style="{StaticResource ToolbarSep}"/>

        <!-- Group 5: Settings / Help -->
        <Button Style="{StaticResource TabItemStyle}"
                ToolTip="단축키 도움말 (Ctrl+B /)"
                Click="HelpButton_Click">
          <TextBlock Style="{StaticResource MdlIcon}" Text="&#xE9CE;"/>
        </Button>
        <Button Style="{StaticResource TabItemStyle}"
                ToolTip="Settings"
                Click="SettingsButton_Click">
          <TextBlock Style="{StaticResource MdlIcon}" Text="&#xE713;"/>
        </Button>
      </StackPanel>
    </Grid>

    <!-- ── Pane / Dashboard area ─────────────────────────────────────────── -->
    <local:PaneContainer x:Name="PaneContainer"
                         Grid.Row="1"
                         Tab="{Binding ActiveTab}"
                         AssetsPath="{Binding AssetsPath, RelativeSource={RelativeSource AncestorType=Window}}">
      <local:PaneContainer.Style>
        <Style TargetType="local:PaneContainer">
          <Setter Property="Visibility" Value="Visible"/>
          <Style.Triggers>
            <DataTrigger Binding="{Binding ActiveTab.IsDashboard}" Value="True">
              <Setter Property="Visibility" Value="Collapsed"/>
            </DataTrigger>
          </Style.Triggers>
        </Style>
      </local:PaneContainer.Style>
    </local:PaneContainer>

    <local:DashboardView Grid.Row="1">
      <local:DashboardView.Style>
        <Style TargetType="local:DashboardView">
          <Setter Property="Visibility" Value="Collapsed"/>
          <Style.Triggers>
            <DataTrigger Binding="{Binding ActiveTab.IsDashboard}" Value="True">
              <Setter Property="Visibility" Value="Visible"/>
            </DataTrigger>
          </Style.Triggers>
        </Style>
      </local:DashboardView.Style>
    </local:DashboardView>

    <!-- ── Status bar ────────────────────────────────────────────────────── -->
    <Grid Grid.Row="2" Background="{DynamicResource KmuxBrushCrust}">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="*" />
        <ColumnDefinition Width="Auto" />
      </Grid.ColumnDefinitions>

      <TextBlock Grid.Column="0"
                 x:Name="StatusText"
                 Text="Ready"
                 Foreground="{DynamicResource KmuxBrushSubtext0}"
                 FontSize="11"
                 VerticalAlignment="Center"
                 Margin="8,0" />

      <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="8,0">
        <!-- Recording indicator: shape (dot) + text for accessibility -->
        <StackPanel x:Name="RecordingIndicator" Orientation="Horizontal"
                    Visibility="Collapsed" Margin="0,0,12,0" VerticalAlignment="Center">
          <Ellipse Width="7" Height="7" Fill="{DynamicResource KmuxBrushRed}"
                   Margin="0,0,5,0" VerticalAlignment="Center"/>
          <TextBlock Text="RECORDING"
                     Foreground="{DynamicResource KmuxBrushRed}"
                     FontSize="11" FontWeight="Bold" VerticalAlignment="Center"/>
        </StackPanel>
        <!-- First-run Ctrl+B hint — dismissed after first Ctrl+B press -->
        <Border x:Name="CtrlBHint"
                Background="{DynamicResource KmuxBrushSurface0}"
                CornerRadius="3" Padding="7,2" Margin="0,0,8,0" VerticalAlignment="Center">
          <TextBlock Text="Tip: Ctrl+B is the command prefix"
                     Foreground="{DynamicResource KmuxBrushSubtext1}"
                     FontSize="11" VerticalAlignment="Center"/>
        </Border>
        <TextBlock Text="Ctrl+B → prefix"
                   Foreground="{DynamicResource KmuxBrushSubtext0}"
                   FontSize="11"
                   VerticalAlignment="Center" />
      </StackPanel>
    </Grid>
  </Grid>
</Window>
