<Window x:Class="KMux.UI.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="KMux Settings"
        Width="560" Height="420"
        MinWidth="480" MinHeight="380"
        Background="{DynamicResource KmuxBrushBase}"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize">

  <Window.Resources>
    <Style x:Key="SectionLabel" TargetType="TextBlock">
      <Setter Property="Foreground" Value="{DynamicResource KmuxBrushText}"/>
      <Setter Property="FontSize"   Value="12"/>
      <Setter Property="FontWeight" Value="SemiBold"/>
      <Setter Property="Margin"     Value="0,0,0,6"/>
    </Style>
    <Style x:Key="FieldLabel" TargetType="TextBlock">
      <Setter Property="Foreground"        Value="{DynamicResource KmuxBrushSubtext1}"/>
      <Setter Property="FontSize"          Value="12"/>
      <Setter Property="VerticalAlignment" Value="Center"/>
      <Setter Property="Margin"            Value="0,0,8,0"/>
    </Style>
    <Style x:Key="ActionBtn" TargetType="Button">
      <Setter Property="Background"      Value="{DynamicResource KmuxBrushSurface0}"/>
      <Setter Property="Foreground"      Value="{DynamicResource KmuxBrushText}"/>
      <Setter Property="BorderThickness" Value="0"/>
      <Setter Property="Padding"         Value="14,7"/>
      <Setter Property="Cursor"          Value="Hand"/>
      <Setter Property="Margin"          Value="4,0"/>
      <Setter Property="MinWidth"        Value="70"/>
      <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Border x:Name="Bd"
                    Background="{TemplateBinding Background}"
                    Padding="{TemplateBinding Padding}"
                    CornerRadius="4">
              <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource KmuxBrushSurface1}"/>
              </Trigger>
              <Trigger Property="IsPressed" Value="True">
                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource KmuxBrushSurface0}"/>
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>
    <Style x:Key="ComboStyle" TargetType="ComboBox">
      <Setter Property="Background"      Value="{DynamicResource KmuxBrushSurface0}"/>
      <Setter Property="Foreground"      Value="{DynamicResource KmuxBrushText}"/>
      <Setter Property="BorderBrush"     Value="{DynamicResource KmuxBrushSurface1}"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="Padding"         Value="8,5"/>
    </Style>
  </Window.Resources>

  <Grid x:Name="RootContent" Margin="24" Opacity="0" RenderTransformOrigin="0.5,0.5">
    <Grid.RenderTransform>
      <ScaleTransform x:Name="EntryScale" ScaleX="0.96" ScaleY="0.96"/>
    </Grid.RenderTransform>
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>  <!-- Header -->
      <RowDefinition Height="14"/>
      <RowDefinition Height="Auto"/>  <!-- Theme section -->
      <RowDefinition Height="12"/>
      <RowDefinition Height="Auto"/>  <!-- Font section -->
      <RowDefinition Height="12"/>
      <RowDefinition Height="Auto"/>  <!-- Startup section -->
      <RowDefinition Height="12"/>
      <RowDefinition Height="*"/>     <!-- Preview -->
      <RowDefinition Height="14"/>
      <RowDefinition Height="Auto"/>  <!-- Buttons -->
    </Grid.RowDefinitions>

    <!-- Header -->
    <TextBlock Grid.Row="0"
               Text="Settings"
               Foreground="{DynamicResource KmuxBrushText}"
               FontSize="18" FontWeight="Bold"/>

    <!-- Theme section -->
    <StackPanel Grid.Row="2">
      <TextBlock Style="{StaticResource SectionLabel}" Text="Theme"/>
      <ListBox x:Name="ThemeList"
               Height="120"
               Background="{DynamicResource KmuxBrushMantle}"
               BorderBrush="{DynamicResource KmuxBrushSurface0}"
               BorderThickness="1"
               SelectionChanged="ThemeList_SelectionChanged">
        <ListBox.ItemContainerStyle>
          <Style TargetType="ListBoxItem">
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="Foreground"      Value="{DynamicResource KmuxBrushSubtext1}"/>
            <Setter Property="Padding"         Value="10,6"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Style.Triggers>
              <Trigger Property="IsSelected" Value="True">
                <Setter Property="Background" Value="{DynamicResource KmuxBrushSurface0}"/>
                <Setter Property="Foreground" Value="{DynamicResource KmuxBrushText}"/>
              </Trigger>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="{DynamicResource KmuxBrushBase}"/>
              </Trigger>
            </Style.Triggers>
          </Style>
        </ListBox.ItemContainerStyle>
        <ListBox.ItemTemplate>
          <DataTemplate>
            <StackPanel Orientation="Horizontal">
              <StackPanel Orientation="Horizontal" Margin="0,0,10,0">
                <Rectangle Width="12" Height="12" RadiusX="2" RadiusY="2" Margin="1,0"
                           Fill="{Binding Background}"/>
                <Rectangle Width="12" Height="12" RadiusX="2" RadiusY="2" Margin="1,0"
                           Fill="{Binding Accent}"/>
                <Rectangle Width="12" Height="12" RadiusX="2" RadiusY="2" Margin="1,0"
                           Fill="{Binding Green}"/>
                <Rectangle Width="12" Height="12" RadiusX="2" RadiusY="2" Margin="1,0"
                           Fill="{Binding Red}"/>
              </StackPanel>
              <TextBlock Text="{Binding Name}" VerticalAlignment="Center"/>
            </StackPanel>
          </DataTemplate>
        </ListBox.ItemTemplate>
      </ListBox>
    </StackPanel>

    <!-- Font section -->
    <StackPanel Grid.Row="4">
      <TextBlock Style="{StaticResource SectionLabel}" Text="Terminal Font"/>
      <StackPanel Orientation="Horizontal">
        <TextBlock Style="{StaticResource FieldLabel}" Text="Family" Width="46"/>
        <ComboBox x:Name="FontFamilyCombo"
                  Style="{StaticResource ComboStyle}"
                  MinWidth="180"
                  SelectionChanged="FontFamilyCombo_SelectionChanged"/>
        <TextBlock Style="{StaticResource FieldLabel}" Text="Size" Width="34" Margin="16,0,8,0"/>
        <ComboBox x:Name="FontSizeCombo"
                  Style="{StaticResource ComboStyle}"
                  MinWidth="72"
                  SelectionChanged="FontSizeCombo_SelectionChanged"/>
      </StackPanel>
    </StackPanel>

    <!-- Startup section -->
    <StackPanel Grid.Row="6">
      <TextBlock Style="{StaticResource SectionLabel}" Text="Startup"/>
      <CheckBox x:Name="RestoreOnStartupCheck"
                Content="앱 시작 시 마지막 세션 복원 (창·탭·pane 레이아웃 및 Claude 세션)"
                Foreground="{DynamicResource KmuxBrushText}"
                FontSize="12"
                Checked="RestoreOnStartupCheck_Changed"
                Unchecked="RestoreOnStartupCheck_Changed"/>
    </StackPanel>

    <!-- Preview -->
    <Grid Grid.Row="8">
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="*"/>
      </Grid.RowDefinitions>
      <TextBlock Grid.Row="0" Style="{StaticResource SectionLabel}" Text="Preview" Margin="0,0,0,6"/>
      <Border Grid.Row="1"
              Background="{DynamicResource KmuxBrushMantle}"
              BorderBrush="{DynamicResource KmuxBrushSurface0}"
              BorderThickness="1"
              Padding="12,10">
        <StackPanel>
          <TextBlock x:Name="PreviewText1"
                     Text="$ git log --oneline"
                     FontSize="14" Foreground="{DynamicResource KmuxBrushText}"/>
          <TextBlock x:Name="PreviewText2"
                     Text="a4f3c21 fix: resolve auth race condition"
                     FontSize="14" Foreground="{DynamicResource KmuxBrushGreen}" Margin="0,2,0,0"/>
          <TextBlock x:Name="PreviewText3"
                     Text="D:\projects\app 0123456789 !@#$%^&amp;*()"
                     FontSize="14" Foreground="{DynamicResource KmuxBrushAccent}" Margin="0,2,0,0"/>
        </StackPanel>
      </Border>
    </Grid>

    <!-- Bottom buttons: OK | Cancel (Apply is implicit in OK) -->
    <StackPanel Grid.Row="10" Orientation="Horizontal" HorizontalAlignment="Right">
      <Button Content="OK"     Style="{StaticResource ActionBtn}" Click="OkBtn_Click"/>
      <Button Content="Apply"  Style="{StaticResource ActionBtn}" Click="ApplyBtn_Click"/>
      <Button Content="Cancel" Style="{StaticResource ActionBtn}" Click="CancelBtn_Click"/>
    </StackPanel>
  </Grid>
</Window>
