<Window x:Class="KMux.UI.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="KMux Settings"
        Width="600" Height="480"
        Background="#1e1e2e"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">

  <Window.Resources>
    <Style x:Key="SectionLabel" TargetType="TextBlock">
      <Setter Property="Foreground" Value="#cdd6f4"/>
      <Setter Property="FontSize"   Value="13"/>
      <Setter Property="FontWeight" Value="SemiBold"/>
      <Setter Property="Margin"     Value="0,0,0,8"/>
    </Style>
    <Style x:Key="FieldLabel" TargetType="TextBlock">
      <Setter Property="Foreground"       Value="#a6adc8"/>
      <Setter Property="FontSize"         Value="12"/>
      <Setter Property="VerticalAlignment" Value="Center"/>
      <Setter Property="Margin"           Value="0,0,8,0"/>
    </Style>
    <Style x:Key="ActionBtn" TargetType="Button">
      <Setter Property="Background"    Value="#313244"/>
      <Setter Property="Foreground"    Value="#cdd6f4"/>
      <Setter Property="BorderThickness" Value="0"/>
      <Setter Property="Padding"       Value="14,7"/>
      <Setter Property="Cursor"        Value="Hand"/>
      <Setter Property="Margin"        Value="4,0"/>
      <Setter Property="MinWidth"      Value="70"/>
    </Style>
    <Style x:Key="ComboStyle" TargetType="ComboBox">
      <Setter Property="Background"    Value="#313244"/>
      <Setter Property="Foreground"    Value="#cdd6f4"/>
      <Setter Property="BorderBrush"   Value="#45475a"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="Padding"       Value="8,5"/>
      <Setter Property="MinWidth"      Value="180"/>
    </Style>
  </Window.Resources>

  <Grid Margin="24">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>   <!-- Header -->
      <RowDefinition Height="16"/>
      <RowDefinition Height="*"/>      <!-- Content -->
      <RowDefinition Height="16"/>
      <RowDefinition Height="Auto"/>   <!-- Buttons -->
    </Grid.RowDefinitions>

    <!-- Header -->
    <TextBlock Grid.Row="0"
               Text="Settings"
               Foreground="#cdd6f4"
               FontSize="18"
               FontWeight="Bold"/>

    <!-- Content -->
    <Grid Grid.Row="2">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="*"/>
        <ColumnDefinition Width="20"/>
        <ColumnDefinition Width="*"/>
      </Grid.ColumnDefinitions>

      <!-- Left: Theme selection -->
      <StackPanel Grid.Column="0">
        <TextBlock Style="{StaticResource SectionLabel}" Text="Theme"/>
        <ListBox x:Name="ThemeList"
                 Background="#181825"
                 BorderBrush="#313244"
                 BorderThickness="1"
                 SelectionChanged="ThemeList_SelectionChanged"
                 Height="320">
          <ListBox.ItemContainerStyle>
            <Style TargetType="ListBoxItem">
              <Setter Property="Background"   Value="Transparent"/>
              <Setter Property="Foreground"   Value="#a6adc8"/>
              <Setter Property="Padding"      Value="10,7"/>
              <Setter Property="BorderThickness" Value="0"/>
              <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                  <Setter Property="Background" Value="#313244"/>
                  <Setter Property="Foreground" Value="#cdd6f4"/>
                </Trigger>
                <Trigger Property="IsMouseOver" Value="True">
                  <Setter Property="Background" Value="#24283b"/>
                </Trigger>
              </Style.Triggers>
            </Style>
          </ListBox.ItemContainerStyle>
          <ListBox.ItemTemplate>
            <DataTemplate>
              <StackPanel Orientation="Horizontal">
                <!-- Color swatches -->
                <StackPanel x:Name="Swatches" Orientation="Horizontal" Margin="0,0,10,0">
                  <Rectangle Width="12" Height="12" RadiusX="2" RadiusY="2" Margin="1,0"
                             Fill="{Binding Background}"/>
                  <Rectangle Width="12" Height="12" RadiusX="2" RadiusY="2" Margin="1,0"
                             Fill="{Binding Accent}"/>
                  <Rectangle Width="12" Height="12" RadiusX="2" RadiusY="2" Margin="1,0"
                             Fill="{Binding Green}"/>
                  <Rectangle Width="12" Height="12" RadiusX="2" RadiusY="2" Margin="1,0"
                             Fill="{Binding Red}"/>
                </StackPanel>
                <TextBlock Text="{Binding Name}" VerticalAlignment="Center"/>
              </StackPanel>
            </DataTemplate>
          </ListBox.ItemTemplate>
        </ListBox>
      </StackPanel>

      <!-- Right: Font settings -->
      <StackPanel Grid.Column="2">
        <TextBlock Style="{StaticResource SectionLabel}" Text="Terminal Font"/>

        <!-- Font family -->
        <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
          <TextBlock Style="{StaticResource FieldLabel}" Text="Family" Width="50"/>
          <ComboBox x:Name="FontFamilyCombo"
                    Style="{StaticResource ComboStyle}"
                    SelectionChanged="FontFamilyCombo_SelectionChanged"/>
        </StackPanel>

        <!-- Font size -->
        <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
          <TextBlock Style="{StaticResource FieldLabel}" Text="Size" Width="50"/>
          <ComboBox x:Name="FontSizeCombo"
                    Style="{StaticResource ComboStyle}"
                    MinWidth="80"
                    SelectionChanged="FontSizeCombo_SelectionChanged"/>
        </StackPanel>

        <!-- Preview box -->
        <TextBlock Style="{StaticResource SectionLabel}" Text="Preview" Margin="0,8,0,6"/>
        <Border Background="#181825" BorderBrush="#313244" BorderThickness="1" Padding="12,10">
          <StackPanel>
            <TextBlock x:Name="PreviewText1"
                       Text="$ echo 'Hello, World!'"
                       FontSize="14" Foreground="#cdd6f4"/>
            <TextBlock x:Name="PreviewText2"
                       Text="Hello, World!"
                       FontSize="14" Foreground="#a6e3a1" Margin="0,2,0,0"/>
            <TextBlock x:Name="PreviewText3"
                       Text="abcdefghijklmnopqrstuvwxyz 0123456789"
                       FontSize="14" Foreground="#89b4fa" Margin="0,2,0,0"/>
          </StackPanel>
        </Border>
      </StackPanel>
    </Grid>

    <!-- Bottom buttons -->
    <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right">
      <Button Content="Apply"  Style="{StaticResource ActionBtn}" Click="ApplyBtn_Click"/>
      <Button Content="OK"     Style="{StaticResource ActionBtn}" Click="OkBtn_Click"/>
      <Button Content="Cancel" Style="{StaticResource ActionBtn}" Click="CancelBtn_Click"/>
    </StackPanel>
  </Grid>
</Window>
