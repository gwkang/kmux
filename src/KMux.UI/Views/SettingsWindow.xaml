<Window x:Class="KMux.UI.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="KMux Settings"
        Icon="pack://application:,,,/KMux;component/Assets/kmux.ico"
        Width="560" Height="460"
        MinWidth="480" MinHeight="420"
        Background="{DynamicResource KmuxBrushBase}"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize">

  <Window.Resources>
    <Style x:Key="SectionLabel" TargetType="TextBlock">
      <Setter Property="Foreground" Value="{DynamicResource KmuxBrushSubtext1}"/>
      <Setter Property="FontSize"   Value="10"/>
      <Setter Property="FontWeight" Value="SemiBold"/>
      <Setter Property="Margin"     Value="0,0,0,7"/>
    </Style>
    <Style x:Key="FieldLabel" TargetType="TextBlock">
      <Setter Property="Foreground"        Value="{DynamicResource KmuxBrushSubtext1}"/>
      <Setter Property="FontSize"          Value="12"/>
      <Setter Property="VerticalAlignment" Value="Center"/>
      <Setter Property="Margin"            Value="0,0,8,0"/>
    </Style>
    <Style x:Key="ActionBtn" TargetType="Button">
      <Setter Property="Background"      Value="{DynamicResource KmuxBrushSurface0}"/>
      <Setter Property="Foreground"      Value="{DynamicResource KmuxBrushText}"/>
      <Setter Property="BorderThickness" Value="0"/>
      <Setter Property="Padding"         Value="16,7"/>
      <Setter Property="Cursor"          Value="Hand"/>
      <Setter Property="Margin"          Value="4,0"/>
      <Setter Property="MinWidth"        Value="70"/>
      <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Border x:Name="Bd"
                    Background="{TemplateBinding Background}"
                    Padding="{TemplateBinding Padding}"
                    CornerRadius="4">
              <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource KmuxBrushSurface1}"/>
              </Trigger>
              <Trigger Property="IsPressed" Value="True">
                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource KmuxBrushSurface0}"/>
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>
    <!-- Primary action button (OK): inherits layout from ActionBtn, overrides colors and hover behavior -->
    <Style x:Key="PrimaryBtn" TargetType="Button" BasedOn="{StaticResource ActionBtn}">
      <Setter Property="Background"  Value="{DynamicResource KmuxBrushAccent}"/>
      <Setter Property="Foreground"  Value="{DynamicResource KmuxBrushBase}"/>
      <Setter Property="FontWeight"  Value="SemiBold"/>
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Border x:Name="Bd"
                    Background="{TemplateBinding Background}"
                    Padding="{TemplateBinding Padding}"
                    CornerRadius="4">
              <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="Bd" Property="Opacity" Value="0.85"/>
              </Trigger>
              <Trigger Property="IsPressed" Value="True">
                <Setter TargetName="Bd" Property="Opacity" Value="0.7"/>
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>
    <Style x:Key="ComboStyle" TargetType="ComboBox">
      <Setter Property="Background"      Value="{DynamicResource KmuxBrushSurface0}"/>
      <Setter Property="Foreground"      Value="{DynamicResource KmuxBrushText}"/>
      <Setter Property="BorderBrush"     Value="{DynamicResource KmuxBrushSurface1}"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="Padding"         Value="8,5"/>
    </Style>
  </Window.Resources>

  <Grid x:Name="RootContent" Margin="24" Opacity="0" RenderTransformOrigin="0.5,0.5">
    <Grid.RenderTransform>
      <ScaleTransform x:Name="EntryScale" ScaleX="0.96" ScaleY="0.96"/>
    </Grid.RenderTransform>
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>  <!-- Header -->
      <RowDefinition Height="16"/>
      <RowDefinition Height="Auto"/>  <!-- Theme section -->
      <RowDefinition Height="14"/>
      <RowDefinition Height="Auto"/>  <!-- Font section -->
      <RowDefinition Height="14"/>
      <RowDefinition Height="Auto"/>  <!-- Startup section -->
      <RowDefinition Height="12"/>
      <RowDefinition Height="*"/>     <!-- Preview -->
      <RowDefinition Height="14"/>
      <RowDefinition Height="Auto"/>  <!-- Buttons -->
    </Grid.RowDefinitions>

    <!-- Header -->
    <TextBlock Grid.Row="0"
               Text="Settings"
               Foreground="{DynamicResource KmuxBrushText}"
               FontSize="18" FontWeight="Bold"/>

    <!-- Theme section -->
    <StackPanel Grid.Row="2">
      <TextBlock Style="{StaticResource SectionLabel}" Text="THEME"/>
      <ListBox x:Name="ThemeList"
               Height="126"
               Background="{DynamicResource KmuxBrushMantle}"
               BorderBrush="{DynamicResource KmuxBrushSurface0}"
               BorderThickness="1"
               SelectionChanged="ThemeList_SelectionChanged">
        <ListBox.ItemContainerStyle>
          <Style TargetType="ListBoxItem">
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="Foreground"      Value="{DynamicResource KmuxBrushSubtext1}"/>
            <Setter Property="Padding"         Value="10,5"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Style.Triggers>
              <Trigger Property="IsSelected" Value="True">
                <Setter Property="Background" Value="{DynamicResource KmuxBrushSurface0}"/>
                <Setter Property="Foreground" Value="{DynamicResource KmuxBrushText}"/>
              </Trigger>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="{DynamicResource KmuxBrushBase}"/>
              </Trigger>
            </Style.Triggers>
          </Style>
        </ListBox.ItemContainerStyle>
        <ListBox.ItemTemplate>
          <DataTemplate>
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
              <!-- Mini palette strip: colors shown against the theme's own background -->
              <Border Background="{Binding Background}"
                      CornerRadius="3"
                      Padding="5,3"
                      Margin="0,0,10,0"
                      BorderBrush="{DynamicResource KmuxBrushSurface1}"
                      BorderThickness="1">
                <StackPanel Orientation="Horizontal">
                  <Rectangle Width="14" Height="14" RadiusX="2" RadiusY="2" Margin="1,0"
                             Fill="{Binding Text}"/>
                  <Rectangle Width="14" Height="14" RadiusX="2" RadiusY="2" Margin="1,0"
                             Fill="{Binding Accent}"/>
                  <Rectangle Width="14" Height="14" RadiusX="2" RadiusY="2" Margin="1,0"
                             Fill="{Binding Green}"/>
                  <Rectangle Width="14" Height="14" RadiusX="2" RadiusY="2" Margin="1,0"
                             Fill="{Binding Red}"/>
                </StackPanel>
              </Border>
              <TextBlock Text="{Binding Name}" VerticalAlignment="Center" FontSize="12"/>
            </StackPanel>
          </DataTemplate>
        </ListBox.ItemTemplate>
      </ListBox>
    </StackPanel>

    <!-- Font section -->
    <StackPanel Grid.Row="4">
      <TextBlock Style="{StaticResource SectionLabel}" Text="TERMINAL FONT"/>
      <StackPanel Orientation="Horizontal">
        <TextBlock Style="{StaticResource FieldLabel}" Text="Family" Width="46"/>
        <ComboBox x:Name="FontFamilyCombo"
                  Style="{StaticResource ComboStyle}"
                  MinWidth="180"
                  SelectionChanged="FontFamilyCombo_SelectionChanged"/>
        <TextBlock Style="{StaticResource FieldLabel}" Text="Size" Width="34" Margin="16,0,8,0"/>
        <ComboBox x:Name="FontSizeCombo"
                  Style="{StaticResource ComboStyle}"
                  MinWidth="72"
                  SelectionChanged="FontSizeCombo_SelectionChanged"/>
      </StackPanel>
    </StackPanel>

    <!-- Startup section -->
    <StackPanel Grid.Row="6">
      <TextBlock Style="{StaticResource SectionLabel}" Text="STARTUP"/>
      <CheckBox x:Name="RestoreOnStartupCheck"
                Content="앱 시작 시 마지막 세션 복원 (창·탭·pane 레이아웃 및 Claude 세션)"
                Foreground="{DynamicResource KmuxBrushText}"
                FontSize="12"
                Checked="RestoreOnStartupCheck_Changed"
                Unchecked="RestoreOnStartupCheck_Changed"/>
    </StackPanel>

    <!-- Preview: reflects the selected (draft) theme and font in real time -->
    <Grid Grid.Row="8">
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="*"/>
      </Grid.RowDefinitions>
      <TextBlock Grid.Row="0" Style="{StaticResource SectionLabel}" Text="PREVIEW"/>
      <Border x:Name="PreviewBorder"
              Grid.Row="1"
              BorderBrush="{DynamicResource KmuxBrushSurface0}"
              BorderThickness="1"
              CornerRadius="4"
              Padding="14,10">
        <StackPanel>
          <TextBlock x:Name="PreviewText1"
                     Text="$ claude --continue"
                     FontSize="14"/>
          <TextBlock x:Name="PreviewText2"
                     Text="&gt; Analyzing workspace (3 panes active)..."
                     FontSize="14" Margin="0,3,0,0"/>
          <TextBlock x:Name="PreviewText3"
                     Text="&#10003; Task complete: auth.ts refactored (+24 -8)"
                     FontSize="14" Margin="0,3,0,0"/>
          <TextBlock x:Name="PreviewText4"
                     Text="&#10007; Error: terminal pane 2 disconnected"
                     FontSize="14" Margin="0,3,0,0"/>
        </StackPanel>
      </Border>
    </Grid>

    <!-- Bottom buttons: Apply (secondary) | OK (primary) | Cancel -->
    <StackPanel Grid.Row="10" Orientation="Horizontal" HorizontalAlignment="Right">
      <Button Content="Apply"  Style="{StaticResource ActionBtn}" Click="ApplyBtn_Click"/>
      <Button Content="OK"     Style="{StaticResource PrimaryBtn}" Click="OkBtn_Click"/>
      <Button Content="Cancel" Style="{StaticResource ActionBtn}" Click="CancelBtn_Click"/>
    </StackPanel>
  </Grid>
</Window>
