<Window x:Class="KMux.UI.Views.SessionManagerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Session Manager"
        Width="560" Height="420"
        MinWidth="400" MinHeight="320"
        Background="{DynamicResource KmuxBrushBase}"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize">

  <Window.Resources>
    <Style x:Key="ActionBtn" TargetType="Button">
      <Setter Property="Background"      Value="{DynamicResource KmuxBrushSurface0}"/>
      <Setter Property="Foreground"      Value="{DynamicResource KmuxBrushText}"/>
      <Setter Property="BorderThickness" Value="0"/>
      <Setter Property="Padding"         Value="12,6"/>
      <Setter Property="Cursor"          Value="Hand"/>
      <Setter Property="Margin"          Value="4,0"/>
      <Setter Property="MinWidth"        Value="64"/>
      <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Border x:Name="Bd"
                    Background="{TemplateBinding Background}"
                    Padding="{TemplateBinding Padding}"
                    CornerRadius="4">
              <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource KmuxBrushSurface1}"/>
              </Trigger>
              <Trigger Property="IsPressed" Value="True">
                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource KmuxBrushSurface0}"/>
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <!-- ListView column header styling -->
    <Style TargetType="GridViewColumnHeader">
      <Setter Property="Background"      Value="{DynamicResource KmuxBrushSurface0}"/>
      <Setter Property="Foreground"      Value="{DynamicResource KmuxBrushSubtext1}"/>
      <Setter Property="Padding"         Value="8,5"/>
      <Setter Property="BorderBrush"     Value="{DynamicResource KmuxBrushSurface1}"/>
      <Setter Property="BorderThickness" Value="0,0,0,1"/>
      <Setter Property="FontSize"        Value="11"/>
      <Setter Property="HorizontalContentAlignment" Value="Left"/>
    </Style>
  </Window.Resources>

  <Grid x:Name="RootContent" Margin="16" Opacity="0" RenderTransformOrigin="0.5,0.5">
    <Grid.RenderTransform>
      <ScaleTransform x:Name="EntryScale" ScaleX="0.96" ScaleY="0.96"/>
    </Grid.RenderTransform>
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="*"/>
      <RowDefinition Height="Auto"/>
    </Grid.RowDefinitions>

    <TextBlock Grid.Row="0"
               Text="Saved Sessions"
               Foreground="{DynamicResource KmuxBrushText}"
               FontSize="16" FontWeight="SemiBold"
               Margin="0,0,0,12"/>

    <ListView Grid.Row="1" x:Name="SessionList"
              Background="{DynamicResource KmuxBrushMantle}"
              BorderBrush="{DynamicResource KmuxBrushSurface0}"
              Foreground="{DynamicResource KmuxBrushText}"
              SelectionMode="Single">
      <ListView.ItemContainerStyle>
        <Style TargetType="ListViewItem">
          <Setter Property="Padding"         Value="4,5"/>
          <Setter Property="BorderThickness" Value="0"/>
          <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
          <Style.Triggers>
            <Trigger Property="IsSelected" Value="True">
              <Setter Property="Background" Value="{DynamicResource KmuxBrushSurface0}"/>
            </Trigger>
            <Trigger Property="IsMouseOver" Value="True">
              <Setter Property="Background" Value="{DynamicResource KmuxBrushBase}"/>
            </Trigger>
          </Style.Triggers>
        </Style>
      </ListView.ItemContainerStyle>
      <ListView.View>
        <GridView>
          <GridViewColumn Header="Name"    Width="160" DisplayMemberBinding="{Binding Name}"/>
          <GridViewColumn Header="Saved"   Width="160" DisplayMemberBinding="{Binding SavedAt}"/>
          <GridViewColumn Header="Windows" Width="80"  DisplayMemberBinding="{Binding WindowCount}"/>
        </GridView>
      </ListView.View>
    </ListView>

    <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right"
                Margin="0,12,0,0">
      <Button Content="Save Current" Style="{StaticResource ActionBtn}" Click="SaveBtn_Click"/>
      <Button Content="Load"         Style="{StaticResource ActionBtn}" Click="LoadBtn_Click"/>
      <Button Content="Delete"       Style="{StaticResource ActionBtn}" Click="DeleteBtn_Click"
              Foreground="{DynamicResource KmuxBrushRed}"/>
      <Button Content="Close"        Style="{StaticResource ActionBtn}" Click="CloseBtn_Click"/>
    </StackPanel>
  </Grid>
</Window>

