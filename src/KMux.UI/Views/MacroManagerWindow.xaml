<Window x:Class="KMux.UI.Views.MacroManagerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Macro Manager"
        Width="680" Height="520"
        Background="#1e1e2e"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize">

  <Window.Resources>
    <Style x:Key="ActionBtn" TargetType="Button">
      <Setter Property="Background" Value="#313244"/>
      <Setter Property="Foreground" Value="#cdd6f4"/>
      <Setter Property="BorderThickness" Value="0"/>
      <Setter Property="Padding" Value="12,6"/>
      <Setter Property="Cursor" Value="Hand"/>
      <Setter Property="Margin" Value="4,0"/>
    </Style>
    <Style x:Key="Label" TargetType="TextBlock">
      <Setter Property="Foreground" Value="#a6adc8"/>
      <Setter Property="FontSize" Value="12"/>
    </Style>
  </Window.Resources>

  <Grid Margin="16">
    <Grid.ColumnDefinitions>
      <ColumnDefinition Width="220"/>
      <ColumnDefinition Width="8"/>
      <ColumnDefinition Width="*"/>
    </Grid.ColumnDefinitions>
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="*"/>
      <RowDefinition Height="Auto"/>
    </Grid.RowDefinitions>

    <!-- Left: macro list -->
    <TextBlock Grid.Column="0" Grid.Row="0"
               Text="Macros" Foreground="#cdd6f4" FontSize="15" FontWeight="SemiBold"
               Margin="0,0,0,8"/>

    <ListBox Grid.Column="0" Grid.Row="1"
             x:Name="MacroList"
             Background="#181825" BorderBrush="#313244" Foreground="#cdd6f4"
             SelectionChanged="MacroList_SelectionChanged">
      <ListBox.ItemTemplate>
        <DataTemplate>
          <TextBlock Text="{Binding Name}" Padding="4,2"/>
        </DataTemplate>
      </ListBox.ItemTemplate>
    </ListBox>

    <!-- Right: detail / editor -->
    <TextBlock Grid.Column="2" Grid.Row="0"
               Text="Actions" Foreground="#cdd6f4" FontSize="15" FontWeight="SemiBold"
               Margin="0,0,0,8"/>

    <Grid Grid.Column="2" Grid.Row="1">
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="*"/>
        <RowDefinition Height="Auto"/>
      </Grid.RowDefinitions>

      <!-- Name + key binding -->
      <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
        <TextBlock Style="{StaticResource Label}" Text="Name:" VerticalAlignment="Center"/>
        <TextBox x:Name="MacroNameBox" Width="160"
                 Background="#313244" Foreground="#cdd6f4" BorderBrush="#45475a"
                 Padding="6,4"/>
        <TextBlock Style="{StaticResource Label}" Text="Hotkey:" VerticalAlignment="Center"/>
        <TextBox x:Name="HotkeyBox" Width="100"
                 Background="#313244" Foreground="#cdd6f4" BorderBrush="#45475a"
                 Padding="6,4" ToolTip="e.g. Ctrl+B 1"/>
      </StackPanel>

      <!-- Action list (editable) -->
      <DataGrid Grid.Row="1"
                x:Name="ActionGrid"
                Background="#181825"
                Foreground="#cdd6f4"
                RowBackground="#181825"
                AlternatingRowBackground="#1e1e2e"
                BorderBrush="#313244"
                GridLinesVisibility="Horizontal"
                HeadersVisibility="Column"
                AutoGenerateColumns="False"
                CanUserAddRows="False">
        <DataGrid.Columns>
          <DataGridTextColumn Header="Type"    Width="100" Binding="{Binding ActionType}"/>
          <DataGridTextColumn Header="Data"    Width="*"   Binding="{Binding Data}"/>
          <DataGridTextColumn Header="Delay"   Width="70"  Binding="{Binding DelayMs}"/>
        </DataGrid.Columns>
      </DataGrid>

      <!-- Checkbox -->
      <CheckBox Grid.Row="2" x:Name="PreserveTimingsCheck"
                Content="Preserve timings during playback"
                Foreground="#a6adc8" Margin="0,8,0,0" IsChecked="True"/>
    </Grid>

    <!-- Bottom buttons -->
    <StackPanel Grid.Column="0" Grid.ColumnSpan="3" Grid.Row="2"
                Orientation="Horizontal" HorizontalAlignment="Right"
                Margin="0,12,0,0">
      <Button Content="▶ Play"     Style="{StaticResource ActionBtn}" Click="PlayBtn_Click"/>
      <Button Content="💾 Save"     Style="{StaticResource ActionBtn}" Click="SaveBtn_Click"/>
      <Button Content="🗑 Delete"   Style="{StaticResource ActionBtn}" Click="DeleteBtn_Click"
              Foreground="#f38ba8"/>
      <Button Content="Close"      Style="{StaticResource ActionBtn}" Click="CloseBtn_Click"/>
    </StackPanel>
  </Grid>
</Window>
