<Window x:Class="KMux.UI.Views.RecentFoldersWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Recent Folders"
        Width="540" Height="420"
        Background="#1e1e2e"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        MinWidth="360" MinHeight="280">

  <Window.Resources>
    <Style x:Key="ActionBtn" TargetType="Button">
      <Setter Property="Background" Value="#313244"/>
      <Setter Property="Foreground" Value="#cdd6f4"/>
      <Setter Property="BorderThickness" Value="0"/>
      <Setter Property="Padding" Value="12,6"/>
      <Setter Property="Cursor" Value="Hand"/>
    </Style>
  </Window.Resources>

  <Grid Margin="16">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="*"/>
      <RowDefinition Height="Auto"/>
    </Grid.RowDefinitions>

    <TextBlock Grid.Row="0" Text="Recent Folders"
               Foreground="#cdd6f4" FontSize="16" FontWeight="SemiBold"
               Margin="0,0,0,12"/>

    <ListBox Grid.Row="1" x:Name="FolderList"
             Background="#181825"
             BorderBrush="#313244"
             Foreground="#cdd6f4"
             SelectionMode="Single"
             ScrollViewer.HorizontalScrollBarVisibility="Auto">
      <ListBox.ItemContainerStyle>
        <Style TargetType="ListBoxItem">
          <Setter Property="Padding" Value="8,4"/>
          <Setter Property="FontFamily" Value="Cascadia Code, Consolas, monospace"/>
          <Setter Property="FontSize" Value="12"/>
          <Style.Triggers>
            <Trigger Property="IsSelected" Value="True">
              <Setter Property="Background" Value="#45475a"/>
            </Trigger>
            <Trigger Property="IsMouseOver" Value="True">
              <Setter Property="Background" Value="#313244"/>
            </Trigger>
          </Style.Triggers>
        </Style>
      </ListBox.ItemContainerStyle>
    </ListBox>

    <Grid Grid.Row="2" Margin="0,12,0,0">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="*"/>
        <ColumnDefinition Width="Auto"/>
      </Grid.ColumnDefinitions>

      <StackPanel Grid.Column="0" Orientation="Horizontal">
        <Button Content="추가..."   Style="{StaticResource ActionBtn}" Click="AddBtn_Click"/>
        <Button Content="삭제"      Style="{StaticResource ActionBtn}" Click="DeleteBtn_Click"
                Foreground="#f38ba8"/>
        <Button Content="전체 삭제" Style="{StaticResource ActionBtn}" Click="ClearBtn_Click"
                Foreground="#f38ba8"/>
      </StackPanel>

      <Button Grid.Column="1" Content="닫기" Style="{StaticResource ActionBtn}" Click="CloseBtn_Click"/>
    </Grid>
  </Grid>
</Window>
