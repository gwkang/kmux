<UserControl x:Class="KMux.UI.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{DynamicResource KmuxBrushBase}">

  <UserControl.Resources>
    <!-- Transparent button wrapper for tab cards -->
    <Style x:Key="CardButtonStyle" TargetType="Button">
      <Setter Property="Background"               Value="Transparent"/>
      <Setter Property="BorderThickness"          Value="0"/>
      <Setter Property="Padding"                  Value="0"/>
      <Setter Property="Cursor"                   Value="Hand"/>
      <Setter Property="FocusVisualStyle"         Value="{x:Null}"/>
      <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
      <Setter Property="VerticalContentAlignment"   Value="Stretch"/>
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <ContentPresenter/>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>
  </UserControl.Resources>

  <ScrollViewer HorizontalScrollBarVisibility="Disabled"
                VerticalScrollBarVisibility="Auto">
    <StackPanel>

      <!-- Header -->
      <TextBlock Text="Dashboard"
                 Foreground="{DynamicResource KmuxBrushSubtext0}"
                 FontSize="11" FontWeight="SemiBold"
                 Margin="20,16,20,12"
                 TextOptions.TextFormattingMode="Display"/>

      <!-- Tab cards wrap panel -->
      <ItemsControl ItemsSource="{Binding NonDashboardTabs}" Margin="14,0,14,16">
        <ItemsControl.ItemsPanel>
          <ItemsPanelTemplate>
            <WrapPanel Orientation="Horizontal"/>
          </ItemsPanelTemplate>
        </ItemsControl.ItemsPanel>
        <ItemsControl.ItemTemplate>
          <DataTemplate>
            <!-- Clickable card → switch to that tab -->
            <Button Style="{StaticResource CardButtonStyle}"
                    Margin="6"
                    Command="{Binding DataContext.ActivateTabCommand,
                              RelativeSource={RelativeSource AncestorType=UserControl}}"
                    CommandParameter="{Binding}">
              <Border MinWidth="210" MaxWidth="300"
                      CornerRadius="6">
                <Border.Style>
                  <Style TargetType="Border">
                    <Setter Property="Background"    Value="{DynamicResource KmuxBrushSurface0}"/>
                    <Setter Property="BorderThickness" Value="1"/>
                    <Setter Property="BorderBrush"   Value="{DynamicResource KmuxBrushSurface1}"/>
                    <Style.Triggers>
                      <DataTrigger Binding="{Binding IsActive}" Value="True">
                        <Setter Property="BorderBrush" Value="{DynamicResource KmuxBrushAccent}"/>
                      </DataTrigger>
                    </Style.Triggers>
                  </Style>
                </Border.Style>

                <StackPanel>
                  <!-- Card header -->
                  <Border CornerRadius="5,5,0,0" Padding="10,8,10,8">
                    <Border.Style>
                      <Style TargetType="Border">
                        <Setter Property="Background" Value="{DynamicResource KmuxBrushSurface1}"/>
                      </Style>
                    </Border.Style>
                    <Grid>
                      <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <!-- Busy indicator square -->
                        <Rectangle Width="6" Height="6" RadiusX="1" RadiusY="1"
                                   Margin="0,0,7,0" VerticalAlignment="Center">
                          <Rectangle.Style>
                            <Style TargetType="Rectangle">
                              <Setter Property="Fill" Value="Transparent"/>
                              <Style.Triggers>
                                <DataTrigger Binding="{Binding IsBusy}" Value="True">
                                  <Setter Property="Fill" Value="{DynamicResource KmuxBrushGreen}"/>
                                </DataTrigger>
                              </Style.Triggers>
                            </Style>
                          </Rectangle.Style>
                        </Rectangle>
                        <TextBlock Text="{Binding Title}"
                                   Foreground="{DynamicResource KmuxBrushText}"
                                   FontWeight="SemiBold" FontSize="12"
                                   VerticalAlignment="Center"/>
                      </StackPanel>
                      <!-- Active indicator dot -->
                      <Ellipse Width="6" Height="6"
                               HorizontalAlignment="Right" VerticalAlignment="Center">
                        <Ellipse.Style>
                          <Style TargetType="Ellipse">
                            <Setter Property="Fill" Value="Transparent"/>
                            <Style.Triggers>
                              <DataTrigger Binding="{Binding IsActive}" Value="True">
                                <Setter Property="Fill" Value="{DynamicResource KmuxBrushAccent}"/>
                              </DataTrigger>
                            </Style.Triggers>
                          </Style>
                        </Ellipse.Style>
                      </Ellipse>
                    </Grid>
                  </Border>

                  <!-- Pane rows -->
                  <ItemsControl ItemsSource="{Binding AllPanes}" Margin="0,4,0,6">
                    <ItemsControl.ItemTemplate>
                      <DataTemplate>
                        <Grid Margin="10,3">
                          <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                          </Grid.ColumnDefinitions>

                          <!-- Status dot: green=busy, accent=ready, gray=idle -->
                          <Ellipse Grid.Column="0" Width="6" Height="6"
                                   Margin="0,0,8,0" VerticalAlignment="Center">
                            <Ellipse.Style>
                              <Style TargetType="Ellipse">
                                <Setter Property="Fill" Value="{DynamicResource KmuxBrushOverlay0}"/>
                                <Style.Triggers>
                                  <DataTrigger Binding="{Binding IsClaudeBusy}" Value="True">
                                    <Setter Property="Fill" Value="{DynamicResource KmuxBrushGreen}"/>
                                  </DataTrigger>
                                  <DataTrigger Binding="{Binding IsClaudeReady}" Value="True">
                                    <Setter Property="Fill" Value="{DynamicResource KmuxBrushAccent}"/>
                                  </DataTrigger>
                                </Style.Triggers>
                              </Style>
                            </Ellipse.Style>
                          </Ellipse>

                          <!-- Working directory (short name) -->
                          <TextBlock Grid.Column="1"
                                     Text="{Binding DisplayPath}"
                                     Foreground="{DynamicResource KmuxBrushSubtext1}"
                                     FontSize="11"
                                     TextTrimming="CharacterEllipsis"
                                     VerticalAlignment="Center"/>

                          <!-- Claude activity label -->
                          <TextBlock Grid.Column="2"
                                     Text="{Binding ClaudeActivity}"
                                     Foreground="{DynamicResource KmuxBrushSubtext0}"
                                     FontSize="10"
                                     Margin="6,0,0,0"
                                     MaxWidth="80"
                                     TextTrimming="CharacterEllipsis"
                                     VerticalAlignment="Center"/>
                        </Grid>
                      </DataTemplate>
                    </ItemsControl.ItemTemplate>
                  </ItemsControl>

                </StackPanel>
              </Border>
            </Button>
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>

    </StackPanel>
  </ScrollViewer>
</UserControl>
