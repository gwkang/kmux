<UserControl x:Class="KMux.UI.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{DynamicResource KmuxBrushBase}">

  <UserControl.Resources>
    <!-- Transparent card button — hover/press delegated to inner Border via RelativeSource -->
    <Style x:Key="CardButtonStyle" TargetType="Button">
      <Setter Property="Background"               Value="Transparent"/>
      <Setter Property="BorderThickness"          Value="0"/>
      <Setter Property="Padding"                  Value="0"/>
      <Setter Property="Cursor"                   Value="Hand"/>
      <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
      <Setter Property="VerticalContentAlignment"   Value="Stretch"/>
      <!-- Keyboard focus: dashed accent outline instead of the default ugly rectangle -->
      <Setter Property="FocusVisualStyle">
        <Setter.Value>
          <Style>
            <Setter Property="Control.Template">
              <Setter.Value>
                <ControlTemplate>
                  <Rectangle Margin="2" StrokeThickness="1.5"
                             Stroke="{DynamicResource KmuxBrushAccent}"
                             RadiusX="7" RadiusY="7"
                             StrokeDashArray="3 2" Opacity="0.8"/>
                </ControlTemplate>
              </Setter.Value>
            </Setter>
          </Style>
        </Setter.Value>
      </Setter>
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <ContentPresenter/>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>
  </UserControl.Resources>

  <ScrollViewer HorizontalScrollBarVisibility="Disabled"
                VerticalScrollBarVisibility="Auto">
    <StackPanel>

      <!-- ── Header: tab count + busy count ──────────────────────────────── -->
      <Grid Margin="20,14,20,10">
        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
          <TextBlock FontSize="11"
                     Foreground="{DynamicResource KmuxBrushSubtext0}"
                     VerticalAlignment="Center">
            <Run Text="{Binding NonDashboardTabs.Count, Mode=OneWay}"/>
            <Run Text="개 탭"/>
          </TextBlock>
          <TextBlock Text=" · " FontSize="11"
                     Foreground="{DynamicResource KmuxBrushOverlay0}"
                     VerticalAlignment="Center"/>
          <TextBlock FontSize="11" VerticalAlignment="Center">
            <TextBlock.Style>
              <Style TargetType="TextBlock">
                <Setter Property="Foreground" Value="{DynamicResource KmuxBrushGreen}"/>
                <Style.Triggers>
                  <DataTrigger Binding="{Binding BusyTabCount}" Value="0">
                    <Setter Property="Foreground" Value="{DynamicResource KmuxBrushOverlay0}"/>
                  </DataTrigger>
                </Style.Triggers>
              </Style>
            </TextBlock.Style>
            <Run Text="작업중 "/>
            <Run Text="{Binding BusyTabCount, Mode=OneWay}"/>
          </TextBlock>
        </StackPanel>
      </Grid>

      <!-- Thin divider below header -->
      <Rectangle Height="1" Fill="{DynamicResource KmuxBrushSurface1}"
                 Margin="20,0,20,12"/>

      <!-- ── Tab cards ──────────────────────────────────────────────────── -->
      <ItemsControl ItemsSource="{Binding NonDashboardTabs}" Margin="14,0,14,16">
        <ItemsControl.ItemsPanel>
          <ItemsPanelTemplate>
            <WrapPanel Orientation="Horizontal"/>
          </ItemsPanelTemplate>
        </ItemsControl.ItemsPanel>
        <ItemsControl.ItemTemplate>
          <DataTemplate>
            <Button Width="240" Margin="6"
                    Style="{StaticResource CardButtonStyle}"
                    AutomationProperties.Name="{Binding Title}"
                    Command="{Binding DataContext.ActivateTabCommand,
                              RelativeSource={RelativeSource AncestorType=UserControl}}"
                    CommandParameter="{Binding}">
              <Border CornerRadius="6">
                <Border.Style>
                  <Style TargetType="Border">
                    <Setter Property="Background"      Value="{DynamicResource KmuxBrushSurface0}"/>
                    <Setter Property="BorderThickness" Value="1"/>
                    <Setter Property="BorderBrush"     Value="{DynamicResource KmuxBrushSurface1}"/>
                    <Style.Triggers>
                      <!-- Hover: brighter body + brighter border -->
                      <DataTrigger Binding="{Binding IsMouseOver,
                                   RelativeSource={RelativeSource AncestorType=Button}}"
                                   Value="True">
                        <Setter Property="Background"  Value="{DynamicResource KmuxBrushSurface1}"/>
                        <Setter Property="BorderBrush" Value="{DynamicResource KmuxBrushOverlay0}"/>
                      </DataTrigger>
                      <!-- Press: dim slightly -->
                      <DataTrigger Binding="{Binding IsPressed,
                                   RelativeSource={RelativeSource AncestorType=Button}}"
                                   Value="True">
                        <Setter Property="Opacity" Value="0.78"/>
                      </DataTrigger>
                      <!-- Active tab: accent border -->
                      <DataTrigger Binding="{Binding IsActive}" Value="True">
                        <Setter Property="BorderBrush" Value="{DynamicResource KmuxBrushAccent}"/>
                      </DataTrigger>
                      <!-- Claude busy: green border (highest priority) -->
                      <DataTrigger Binding="{Binding IsClaudeBusy}" Value="True">
                        <Setter Property="BorderBrush" Value="{DynamicResource KmuxBrushGreen}"/>
                      </DataTrigger>
                    </Style.Triggers>
                  </Style>
                </Border.Style>

                <StackPanel>
                  <!-- Card header -->
                  <Border CornerRadius="5,5,0,0" Padding="10,8"
                          Background="{DynamicResource KmuxBrushSurface1}">
                    <Grid>
                      <TextBlock Text="{Binding Title}"
                                 Foreground="{DynamicResource KmuxBrushText}"
                                 FontWeight="SemiBold" FontSize="12"
                                 VerticalAlignment="Center"/>
                      <!-- Active indicator: accent dot + "활성" label on right edge -->
                      <StackPanel Orientation="Horizontal"
                                  HorizontalAlignment="Right" VerticalAlignment="Center"
                                  ToolTip="현재 활성 탭">
                        <StackPanel.Style>
                          <Style TargetType="StackPanel">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                              <DataTrigger Binding="{Binding IsActive}" Value="True">
                                <Setter Property="Visibility" Value="Visible"/>
                              </DataTrigger>
                            </Style.Triggers>
                          </Style>
                        </StackPanel.Style>
                        <Ellipse Width="6" Height="6" Fill="{DynamicResource KmuxBrushAccent}"
                                 VerticalAlignment="Center" Margin="0,0,4,0"/>
                        <TextBlock Text="활성" FontSize="9"
                                   Foreground="{DynamicResource KmuxBrushAccent}"
                                   VerticalAlignment="Center"/>
                      </StackPanel>
                    </Grid>
                  </Border>

                  <!-- Pane rows -->
                  <ItemsControl ItemsSource="{Binding AllPanes}" MinHeight="32" Margin="0,4,0,6">
                    <ItemsControl.ItemTemplate>
                      <DataTemplate>
                        <!-- Left state stripe + content -->
                        <Grid MinHeight="28">

                          <!-- 3 px left stripe — colour + pulse animation driven by Claude state -->
                          <Rectangle Width="3"
                                     HorizontalAlignment="Left"
                                     VerticalAlignment="Stretch">
                            <Rectangle.Style>
                              <Style TargetType="Rectangle">
                                <Setter Property="Fill" Value="Transparent"/>
                                <Style.Triggers>

                                  <!-- Busy: green + pulse -->
                                  <DataTrigger Binding="{Binding IsClaudeBusy}" Value="True">
                                    <Setter Property="Fill" Value="{DynamicResource KmuxBrushGreen}"/>
                                    <DataTrigger.EnterActions>
                                      <BeginStoryboard x:Name="BusyPulse">
                                        <Storyboard RepeatBehavior="Forever" AutoReverse="True">
                                          <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                           From="0.4" To="1.0"
                                                           Duration="0:0:0.85"/>
                                        </Storyboard>
                                      </BeginStoryboard>
                                    </DataTrigger.EnterActions>
                                    <DataTrigger.ExitActions>
                                      <StopStoryboard BeginStoryboardName="BusyPulse"/>
                                      <BeginStoryboard>
                                        <Storyboard>
                                          <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                           To="1.0" Duration="0:0:0.15"/>
                                        </Storyboard>
                                      </BeginStoryboard>
                                    </DataTrigger.ExitActions>
                                  </DataTrigger>

                                  <!-- Ready: accent, solid -->
                                  <DataTrigger Binding="{Binding IsClaudeReady}" Value="True">
                                    <Setter Property="Fill" Value="{DynamicResource KmuxBrushAccent}"/>
                                  </DataTrigger>

                                </Style.Triggers>
                              </Style>
                            </Rectangle.Style>
                          </Rectangle>

                          <!-- Row content — left-padded to clear the stripe -->
                          <StackPanel Margin="11,4,10,4">

                            <!-- Pane name row: name left, spinner right when busy -->
                            <Grid>
                              <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                              </Grid.ColumnDefinitions>

                              <TextBlock Grid.Column="0"
                                         Text="{Binding PaneDisplayName}"
                                         ToolTip="{Binding WorkingDirectory}"
                                         FontSize="11"
                                         TextTrimming="CharacterEllipsis"
                                         VerticalAlignment="Center">
                                <TextBlock.Style>
                                  <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="{DynamicResource KmuxBrushSubtext1}"/>
                                    <Style.Triggers>
                                      <DataTrigger Binding="{Binding IsClaudeBusy}" Value="True">
                                        <Setter Property="Foreground" Value="{DynamicResource KmuxBrushText}"/>
                                      </DataTrigger>
                                    </Style.Triggers>
                                  </Style>
                                </TextBlock.Style>
                              </TextBlock>

                              <!-- Spinning sync icon — visible only when busy -->
                              <TextBlock Grid.Column="1"
                                         Text="&#xE895;"
                                         FontFamily="Segoe MDL2 Assets"
                                         FontSize="10"
                                         Foreground="{DynamicResource KmuxBrushGreen}"
                                         VerticalAlignment="Center"
                                         Margin="5,0,0,0"
                                         RenderTransformOrigin="0.5,0.5">
                                <TextBlock.RenderTransform>
                                  <RotateTransform Angle="0"/>
                                </TextBlock.RenderTransform>
                                <TextBlock.Style>
                                  <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                      <DataTrigger Binding="{Binding IsClaudeBusy}" Value="True">
                                        <Setter Property="Visibility" Value="Visible"/>
                                        <DataTrigger.EnterActions>
                                          <BeginStoryboard>
                                            <Storyboard RepeatBehavior="Forever">
                                              <DoubleAnimation
                                                Storyboard.TargetProperty="(UIElement.RenderTransform).(RotateTransform.Angle)"
                                                From="0" To="360" Duration="0:0:1"/>
                                            </Storyboard>
                                          </BeginStoryboard>
                                        </DataTrigger.EnterActions>
                                      </DataTrigger>
                                    </Style.Triggers>
                                  </Style>
                                </TextBlock.Style>
                              </TextBlock>

                            </Grid>

                            <!-- Claude activity — "생각 중…" placeholder when busy but no text -->
                            <TextBlock Text="{Binding DisplayActivity}"
                                       FontSize="10"
                                       Margin="0,2,0,0"
                                       TextTrimming="CharacterEllipsis">
                              <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                  <Setter Property="Visibility"  Value="Visible"/>
                                  <Setter Property="Foreground"  Value="{DynamicResource KmuxBrushGreen}"/>
                                  <Style.Triggers>
                                    <DataTrigger Binding="{Binding DisplayActivity}" Value="">
                                      <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                  </Style.Triggers>
                                </Style>
                              </TextBlock.Style>
                            </TextBlock>

                            <!-- Session ID — shown only once a Claude session is active -->
                            <TextBlock Text="{Binding ShortSessionId}"
                                       FontSize="9" FontFamily="Consolas"
                                       Foreground="{DynamicResource KmuxBrushOverlay0}"
                                       Margin="0,2,0,0"
                                       TextTrimming="CharacterEllipsis"
                                       ToolTip="{Binding ClaudeSessionId}">
                              <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                  <Setter Property="Visibility" Value="Collapsed"/>
                                  <Style.Triggers>
                                    <DataTrigger Binding="{Binding HasSessionId}" Value="True">
                                      <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                  </Style.Triggers>
                                </Style>
                              </TextBlock.Style>
                            </TextBlock>

                          </StackPanel>
                        </Grid>
                      </DataTemplate>
                    </ItemsControl.ItemTemplate>
                  </ItemsControl>

                </StackPanel>
              </Border>
            </Button>
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>

      <!-- ── Empty state (shown when no tabs are open) ─────────────────── -->
      <StackPanel HorizontalAlignment="Center" Margin="0,60,0,0">
        <StackPanel.Style>
          <Style TargetType="StackPanel">
            <Setter Property="Visibility" Value="Collapsed"/>
            <Style.Triggers>
              <DataTrigger Binding="{Binding HasNoTabs}" Value="True">
                <Setter Property="Visibility" Value="Visible"/>
              </DataTrigger>
            </Style.Triggers>
          </Style>
        </StackPanel.Style>
        <TextBlock Text="&#xE710;"
                   FontFamily="Segoe MDL2 Assets" FontSize="36"
                   Foreground="{DynamicResource KmuxBrushOverlay0}"
                   HorizontalAlignment="Center" Margin="0,0,0,14"/>
        <TextBlock Text="아직 열린 탭이 없습니다"
                   Foreground="{DynamicResource KmuxBrushSubtext0}"
                   FontSize="13"
                   HorizontalAlignment="Center"/>
        <Button Content="Claude 탭 열기"
                Command="{Binding NewClaudeTabCommand}"
                HorizontalAlignment="Center"
                Margin="0,16,0,0" Padding="20,8"
                FontSize="12" Cursor="Hand">
          <Button.Style>
            <Style TargetType="Button">
              <Setter Property="Background"      Value="{DynamicResource KmuxBrushAccent}"/>
              <Setter Property="Foreground"      Value="{DynamicResource KmuxBrushBase}"/>
              <Setter Property="BorderThickness" Value="0"/>
              <Setter Property="Template">
                <Setter.Value>
                  <ControlTemplate TargetType="Button">
                    <Border Background="{TemplateBinding Background}"
                            CornerRadius="5" Padding="{TemplateBinding Padding}">
                      <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                  </ControlTemplate>
                </Setter.Value>
              </Setter>
              <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                  <Setter Property="Opacity" Value="0.85"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                  <Setter Property="Opacity" Value="0.7"/>
                </Trigger>
              </Style.Triggers>
            </Style>
          </Button.Style>
        </Button>
      </StackPanel>

    </StackPanel>
  </ScrollViewer>
</UserControl>
