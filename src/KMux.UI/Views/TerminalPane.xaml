<UserControl x:Class="KMux.UI.Views.TerminalPane"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
             Background="{DynamicResource KmuxBrushBase}">

  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="20" />  <!-- Pane header bar (fixed height) -->
      <RowDefinition Height="*"  />  <!-- Terminal content -->
    </Grid.RowDefinitions>

    <!-- Pane header: folder path (left, middle-clipped) + Claude activity (right) -->
    <Border Grid.Row="0"
            Background="{DynamicResource KmuxBrushCrust}"
            Padding="8,0">
      <Grid>
        <TextBlock x:Name="PathText"
                   FontSize="11"
                   Foreground="{DynamicResource KmuxBrushSubtext0}"
                   VerticalAlignment="Center"
                   TextTrimming="CharacterEllipsis" />
        <TextBlock x:Name="ActivityText"
                   FontSize="11"
                   HorizontalAlignment="Right"
                   Foreground="{DynamicResource KmuxBrushSubtext1}"
                   TextTrimming="CharacterEllipsis"
                   VerticalAlignment="Center" />
      </Grid>
    </Border>

    <!-- Focus border indicator (accent color when focused, subtle when not) -->
    <Border x:Name="FocusBorder"
            Grid.Row="1"
            BorderThickness="2"
            BorderBrush="{DynamicResource KmuxBrushSurface0}"
            Panel.ZIndex="1"
            IsHitTestVisible="False" />

    <!-- Activity bar: top strip, visible when Claude is working -->
    <Rectangle x:Name="ActivityBar"
               Grid.Row="1"
               Height="3"
               VerticalAlignment="Top"
               HorizontalAlignment="Stretch"
               Panel.ZIndex="2"
               IsHitTestVisible="False"
               Fill="{DynamicResource KmuxBrushGreen}"
               Opacity="0" />

    <!-- WebView2 terminal -->
    <wv2:WebView2 x:Name="WebView"
                  Grid.Row="1"
                  DefaultBackgroundColor="#FF1E1E2E" />
  </Grid>
</UserControl>
