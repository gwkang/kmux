{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "build KMux",
      "command": "dotnet",
      "type": "process",
      "args": [
        "build",
        "${workspaceFolder}/src/KMux.App/KMux.App.csproj",
        "-c",
        "Debug",
        "-p:Platform=x64",
        "/property:GenerateFullPaths=true",
        "/consoleloggerparameters:NoSummary"
      ],
      "problemMatcher": "$msCompile",
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "presentation": {
        "reveal": "silent",
        "panel": "shared"
      }
    }
  ]
}
